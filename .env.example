# Application
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters
NEXT_PUBLIC_APP_URL=http://localhost:3000
GIT_COMMIT_SHA=local

# PostgreSQL
POSTGRES_USER=nextstarter
POSTGRES_PASSWORD=nextstarter
POSTGRES_DB=nextstarter
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://nextstarter:nextstarter@localhost:5432/nextstarter

# Seed data
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
SUPER_ADMIN_PASSWORD=change-this-password

# Test accounts
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_USER_EMAIL=superadmin@example.com
PLAYWRIGHT_USER_PASSWORD=change-this-password

# Development email flow
EMAIL_PROVIDER=dev-console
OTEL_SERVICE_NAME=nextstarter

# Docker
APP_PORT=3000
POSTGRES_DATA_VOLUME=nextstarter_postgres_data
DOCKER_DATABASE_URL=postgres://nextstarter:nextstarter@postgres:5432/nextstarter

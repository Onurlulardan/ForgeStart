# ============================================================
# ForgeStart environment template
#
# Copy this file to .env (or run `yarn setup`) and fill in the
# Required section. Everything under OPTIONAL has sensible
# defaults and can be left alone unless you opt in to that
# integration.
# ============================================================

# ---------- Required ----------
AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters
AUTH_URL=http://localhost:3000
DATABASE_URL=postgres://forgestart:forgestart@localhost:5432/forgestart
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change-this-password
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Docker Compose defaults ----------
# Only used by docker compose (yarn dev:docker, yarn docker:up).
# Compose interpolates these into service env vars and ports.
POSTGRES_USER=forgestart
POSTGRES_PASSWORD=forgestart
POSTGRES_DB=forgestart

# ============================================================
# OPTIONAL — everything below has defaults; uncomment only what
# you need to override.
# ============================================================

# OPTIONAL: app
# APP_TIMEZONE=Europe/Istanbul
# AUTH_SESSION_MAX_AGE=604800     # 7 days
# AUTH_SESSION_UPDATE_AGE=3600    # 1 hour
# SUPER_ADMIN_FIRST_NAME=Super
# SUPER_ADMIN_LAST_NAME=Admin

# OPTIONAL: storage (default: local disk)
# STORAGE_DRIVER=local            # local | s3
# STORAGE_LOCAL_PATH=./public/uploads
# STORAGE_LOCAL_URL=/uploads
# STORAGE_MAX_FILE_SIZE=10485760  # 10 MB
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ENDPOINT=            # for R2/MinIO; leave empty for AWS
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_PUBLIC_URL=

# OPTIONAL: email (default: console — logs to stdout)
# EMAIL_PROVIDER=console          # console | resend | smtp
# EMAIL_FROM="No Reply <noreply@example.com>"
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false

# OPTIONAL: rate limiting (default: in-memory LRU)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# OPTIONAL: realtime (default port 4000)
# REALTIME_PORT=4000
# REALTIME_URL=http://localhost:4000
# NEXT_PUBLIC_REALTIME_URL=http://localhost:4000

# OPTIONAL: observability
# OTEL_SERVICE_NAME=forgestart
# GIT_COMMIT_SHA=local

# OPTIONAL: Playwright e2e
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_USER_EMAIL=superadmin@example.com
# PLAYWRIGHT_USER_PASSWORD=change-this-password

# Application
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters
AUTH_SESSION_MAX_AGE=604800
AUTH_SESSION_UPDATE_AGE=3600
NEXT_PUBLIC_APP_URL=http://localhost:3000
GIT_COMMIT_SHA=local
APP_TIMEZONE=Europe/Istanbul

# PostgreSQL
POSTGRES_USER=nextstarter
POSTGRES_PASSWORD=nextstarter
POSTGRES_DB=nextstarter
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://nextstarter:nextstarter@localhost:5432/nextstarter

# Seed data
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
SUPER_ADMIN_PASSWORD=change-this-password

# Test accounts
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_USER_EMAIL=superadmin@example.com
PLAYWRIGHT_USER_PASSWORD=change-this-password

# Storage (file upload)
STORAGE_DRIVER=local                # local | s3
STORAGE_LOCAL_PATH=./public/uploads
STORAGE_LOCAL_URL=/uploads
STORAGE_MAX_FILE_SIZE=10485760      # 10 MB default
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT=                # for R2/MinIO; leave empty for AWS
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_PUBLIC_URL=              # CDN/public URL prefix

# Email
EMAIL_PROVIDER=console              # console | resend | smtp
EMAIL_FROM=No Reply <noreply@example.com>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Rate limiting (optional; falls back to in-memory LRU)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# WebSocket / Realtime
REALTIME_PORT=4000
REALTIME_URL=http://localhost:4000
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000

# Observability
OTEL_SERVICE_NAME=nextstarter

# Docker
APP_PORT=3000
POSTGRES_DATA_VOLUME=nextstarter_postgres_data
DOCKER_DATABASE_URL=postgres://nextstarter:nextstarter@postgres:5432/nextstarter

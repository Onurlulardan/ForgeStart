{
  "name": "nextstarter",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:reset": "tsx db/reset.ts",
    "docker:config": "docker compose config",
    "docker:config:dev": "docker compose --profile dev config",
    "docker:config:prod": "docker compose --profile prod config",
    "docker:up": "docker compose --profile dev up",
    "docker:up:build": "docker compose --profile dev up --build",
    "docker:up:prod": "docker compose --profile prod up --build",
    "docker:down": "docker compose down --remove-orphans",
    "docker:down:volumes": "docker compose down --volumes --remove-orphans",
    "docker:build": "docker compose --profile dev build",
    "docker:build:prod": "docker compose --profile prod build",
    "docker:migrate": "docker compose --profile dev run --rm migrate",
    "docker:seed": "docker compose --profile seed run --rm seed",
    "docker:logs": "docker compose --profile dev logs -f",
    "docker:ps": "docker compose --profile dev ps",
    "verify": "yarn lint && yarn typecheck && yarn test && yarn build"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.2.3",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@auth/drizzle-adapter": "^1.11.2",
    "antd": "^6.4.2",
    "axios": "^1.16.1",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.20.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}

{
  "name": "forgestart",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "concurrently -n next,realtime -c blue,magenta \"node scripts/next-port.mjs dev\" \"node scripts/realtime-dev.mjs\"",
    "dev:docker": "node scripts/docker-dev.mjs",
    "predev": "node scripts/predev.mjs",
    "realtime:start": "tsx server/index.ts",
    "build": "next build",
    "start": "node scripts/next-port.mjs start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "doctor": "node scripts/doctor.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "db:seed:demo": "tsx db/seed-demo.ts",
    "db:studio": "drizzle-kit studio",
    "db:reset": "tsx db/reset.ts",
    "docker:up": "docker compose --profile dev up",
    "docker:up:build": "docker compose --profile dev up --build",
    "docker:up:prod": "docker compose --profile prod up --build",
    "docker:down": "docker compose down --remove-orphans",
    "docker:down:volumes": "docker compose down --volumes --remove-orphans",
    "docker:build": "docker compose --profile dev build",
    "docker:build:prod": "docker compose --profile prod build",
    "docker:migrate": "docker compose --profile dev run --rm migrate",
    "docker:seed": "docker compose --profile seed run --rm seed",
    "docker:logs": "docker compose --profile dev logs -f",
    "docker:ps": "docker compose --profile dev ps",
    "verify": "yarn lint && yarn typecheck && yarn test && yarn build"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-email/components": "^1.0.12",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/core": "^3.23.4",
    "@tiptap/extension-code-block": "^3.23.4",
    "@tiptap/extension-code-block-lowlight": "^3.23.4",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-typography": "^3.23.4",
    "@tiptap/extensions": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "axios": "^1.16.1",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^3.13.0",
    "lowlight": "^3.3.0",
    "lru-cache": "^11.3.6",
    "lucide-react": "^1.16.0",
    "mime-types": "^3.0.2",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-email": "^6.1.4",
    "react-hook-form": "^7.76.0",
    "resend": "^6.12.3",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
